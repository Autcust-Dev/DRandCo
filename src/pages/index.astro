---
import SEO from '../components/SEO.astro';
import '../styles/global.css';
import { db } from '../lib/firebase';
import AppLink from '../components/AppLink.astro';

// Ensure Vercel doesn't infinitely cache this SSR page, but keeps it fast
Astro.response.headers.set('Cache-Control', 's-maxage=1, stale-while-revalidate=59');

let homeHtml = ``;
let policies: any[] = [];

let apps: any[] = [];
let menus: any[] = [];

try {
	const homeDoc = await db.collection('site_content').doc('home').get();
	if (homeDoc.exists) {
		const data = homeDoc.data();
		if (data?.homeHtml) {
			homeHtml = data.homeHtml;
		} else if (data?.headline && data?.description) {
			homeHtml = `<h1 style="font-size: 3.5rem; margin-bottom: 1.5rem;">${data.headline}</h1>\n<p style="color: var(--text-muted); font-size: 1.25rem; margin-bottom: 2rem; max-width: 700px; margin-left: auto; margin-right: auto;">${data.description}</p>`;
		}
	}

	const appsSnapshot = await db.collection('apps').get();
	apps = appsSnapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));

	try {
		const menusSnapshot = await db.collection('menus').orderBy('order', 'asc').get();
		menus = menusSnapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
	} catch (e) {
		const menusSnapshot = await db.collection('menus').get();
		menus = menusSnapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
		menus.sort((a, b) => (a.order || 0) - (b.order || 0));
	}

	const policiesSnapshot = await db.collection('policies').get();
	policies = policiesSnapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
} catch (e) {
	console.error('Error fetching data from Firestore:', e);
}
---

<html lang="en">
	<head>
		<SEO 
			title="DineshReddy&Co"
			description="DineshReddy&Co Portfolio and Policies"
		/>

		<!-- Analytics -->
		<script defer src="/_vercel/insights/script.js"></script>
		<style>
			/* Mega Menu Styles */
			.mega-menu-nav {
				background-color: #000080; /* Dark blue from screenshot */
				width: 100%;
				display: flex;
				justify-content: center;
				position: relative;
				z-index: 1000;
			}
			.mega-menu-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
			}
			.mega-menu-item {
				position: relative;
			}
			.mega-menu-link {
				display: block;
				padding: 1rem 1.5rem;
				color: #ffffff;
				text-decoration: none;
				font-weight: bold;
				font-size: 0.9rem;
				text-transform: uppercase;
				transition: background-color 0.3s;
				cursor: pointer;
			}
			.mega-menu-link:hover {
				background-color: #000044;
			}
			.mega-menu-dropdown {
				position: absolute;
				top: 100%;
				left: 0;
				background-color: #000080;
				min-width: 250px;
				opacity: 0;
				visibility: hidden;
				transform: translateY(10px);
				transition: all 0.3s ease;
				box-shadow: 0 4px 6px rgba(0,0,0,0.3);
				padding: 0.5rem 0;
			}
			.mega-menu-item:hover .mega-menu-dropdown {
				opacity: 1;
				visibility: visible;
				transform: translateY(0);
			}
			.mega-dropdown-link {
				display: block;
				padding: 0.75rem 1.5rem;
				color: #ffffff;
				text-decoration: none;
				font-size: 0.9rem;
				transition: background-color 0.2s;
			}
			.mega-dropdown-link:hover {
				background-color: #000044;
			}
			.mega-dropdown-link::before {
				content: '▸';
				margin-right: 8px;
				font-size: 0.8rem;
			}
			/* Mobile Menu Button */
			.mobile-menu-btn {
				display: none;
				background: none;
				border: none;
				color: white;
				font-size: 1.2rem;
				padding: 1rem;
				cursor: pointer;
				font-weight: bold;
			}
			@media (max-width: 768px) {
				.mega-menu-list {
					flex-direction: column;
					display: none;
					width: 100%;
				}
				.mega-menu-list.active {
					display: flex;
				}
				.mobile-menu-btn {
					display: block;
				}
				.mega-menu-nav {
					flex-direction: column;
				}
				.mega-menu-dropdown {
					position: static;
					opacity: 1;
					visibility: visible;
					transform: none;
					box-shadow: none;
					background-color: #000044;
					padding: 0;
				}
				.mega-menu-link {
					border-bottom: 1px solid rgba(255,255,255,0.1);
				}
			}
		</style>
	</head>
	<body style="margin: 0; position: relative; min-height: 100vh; display: flex; flex-direction: column;">
		<nav class="mega-menu-nav">
			<button class="mobile-menu-btn" onclick="document.getElementById('mega-list').classList.toggle('active')">☰ MENU</button>
			<ul class="mega-menu-list" id="mega-list">
				{menus.map(menu => (
					<li class="mega-menu-item">
						<a class="mega-menu-link">
							{menu.title}
							{menu.items && menu.items.length > 0 ? ' ▾' : ''}
						</a>
						{menu.items && menu.items.length > 0 && (
							<div class="mega-menu-dropdown">
								{menu.items.map((item: any) => (
									<a href={item.url} class="mega-dropdown-link">{item.label}</a>
								))}
							</div>
						)}
					</li>
				))}
				{policies.length > 0 && (
					<li class="mega-menu-item">
						<a class="mega-menu-link">POLICIES ▾</a>
						<div class="mega-menu-dropdown">
							{policies.map(policy => (
								<a href={`/policies/${policy.slug}`} class="mega-dropdown-link">{policy.title}</a>
							))}
						</div>
					</li>
				)}
			</ul>
		</nav>

		<main class="container text-center" style="max-width: 1000px; padding: 2rem; margin: auto;">
			<div style="padding: 4rem 1rem; margin-bottom: 2rem;" set:html={homeHtml}></div>

		</main>

	</body>
</html>

