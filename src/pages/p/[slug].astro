---
import SEO from '../../components/SEO.astro';
import '../../styles/global.css';
import { db } from '../../lib/firebase';

Astro.response.headers.set('Cache-Control', 's-maxage=1, stale-while-revalidate=59');

const { slug } = Astro.params;
if (!slug) {
	return Astro.redirect('/404');
}

let customPage = null;
try {
	const snapshot = await db.collection('menus').get();
	for (const doc of snapshot.docs) {
		const menuData = doc.data();
		if (menuData.items) {
			for (const item of menuData.items) {
				if (item.type === 'page' && item.slug === slug) {
					customPage = item;
					break;
				} else if (item.type === 'submenu' && item.items) {
					const foundChild = item.items.find((child: any) => child.type === 'page' && child.slug === slug);
					if (foundChild) {
						customPage = foundChild;
						break;
					}
				}
			}
			if (customPage) break;
		}
	}
} catch (e) {
	console.error('Error fetching custom page:', e);
}

if (!customPage) {
	return Astro.redirect('/404');
}

const htmlContent = customPage.content;
---

<html lang="en">
	<head>
		<SEO 
			title={`${customPage.label} | DineshReddy&Co`}
			description={`Read the ${customPage.label} page for DineshReddy&Co.`}
			type="article"
		/>

		<!-- Analytics -->
		<script defer src="/_vercel/insights/script.js"></script>
	</head>
	<body>
		<main class="container">
			<div class="glass-panel mb-4">
				<a href="/" class="mb-4" style="display: inline-block;">&larr; Back to Home</a>
				<h1>{customPage.label}</h1>
				<hr class="divider" />
				<div class="markdown-content" set:html={htmlContent}>
				</div>
			</div>
		</main>
	</body>
</html>
